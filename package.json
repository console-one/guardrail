{
  "name": "@console-one/guardrail",
  "version": "0.1.1",
  "description": "Declarative temporal constraint evaluation for API authorization. Identity-keyed resource budgets with automatic dependency discovery and atomic transactional commit.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/console-one/guardrail.git"
  },
  "bugs": {
    "url": "https://github.com/console-one/guardrail/issues"
  },
  "homepage": "https://github.com/console-one/guardrail#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm run smoke",
    "smoke": "node --enable-source-maps dist/smoke.js"
  },
  "keywords": [
    "authorization",
    "rate-limit",
    "constraint",
    "policy",
    "transactional",
    "temporal",
    "declarative",
    "reactive",
    "dependency-graph"
  ],
  "author": "Andrew Chalmers",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
